APP_NAME=Datalyze API
ENVIRONMENT=development
ALLOWED_ORIGINS_RAW=http://localhost:5173,http://127.0.0.1:5173
OLLAMA_HOST=http://127.0.0.1:11434
HEAVY_MODEL=qwen2.5:14b
LIGHT_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text

# --- Database ---
# Host machine (Kartavya): connect to local Postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5433/datalyze
# Teammate on LAN: replace KARTAVYA_LAN_IP with Kartavya's IPv4 (run ipconfig)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@KARTAVYA_LAN_IP:5433/datalyze
