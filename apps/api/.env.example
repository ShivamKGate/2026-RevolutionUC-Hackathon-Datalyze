APP_NAME=Datalyze API
ENVIRONMENT=development
ALLOWED_ORIGINS_RAW=http://localhost:5173,http://127.0.0.1:5173
LLM_PROVIDER=featherless
LLM_BASE_URL=https://api.featherless.ai/v1
LLM_API_KEY=
HEAVY_MODEL=Kimi-K2.5
HEAVY_ALT_MODEL=DeepSeek-V3.2
LIGHT_MODEL=Qwen/Qwen2.5-7B-Instruct
# Custom Featherless slugs (e.g. Qwen/...) require the `litellm` package (see requirements.txt).
EMBEDDING_MODEL=nomic-embed-text

# --- Database ---
# Host machine (Kartavya): connect to local Postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5433/datalyze
# Teammate on LAN: replace KARTAVYA_LAN_IP with Kartavya's IPv4 (run ipconfig)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@KARTAVYA_LAN_IP:5433/datalyze

# --- Orchestrator ---

ORCHESTRATOR_MAX_RETRIES=2

ORCHESTRATOR_TIMEOUT_SECONDS=45

ORCH_MAX_RUN_SECONDS=420



# --- Gemini API ---

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash



# --- ElevenLabs API ---

ELEVENLABS_API_KEY=
# Optional voice ID from ElevenLabs voice library (empty = default)
ELEVENLABS_VOICE_ID=
# Per–pipeline-log ElevenLabs clips are disabled in code (MVP: final insight podcast only).
# Kept for future use if realtime log TTS is re-enabled in orchestrator engine.
ELEVENLABS_PIPELINE_NARRATION=false

# --- Auth / JWT ---
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=48
COOKIE_NAME=datalyze_token
COOKIE_SECURE=false
