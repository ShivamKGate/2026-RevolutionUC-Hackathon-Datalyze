{
  "name": "datalyze",
  "version": "0.1.0",
  "private": true,
  "description": "Hackathon monorepo for Datalyze.",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "postinstall": "node scripts/check-python312.mjs",
    "predev": "npm install",
    "dev": "concurrently -n WEB,API -c cyan,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:api": "node scripts/run-api.mjs",
    "build:web": "npm --prefix apps/web run build"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
