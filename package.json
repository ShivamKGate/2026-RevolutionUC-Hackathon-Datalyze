{
  "name": "datalyze",
  "version": "0.1.0",
  "private": true,
  "description": "Hackathon monorepo for Datalyze.",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n WEB,API -c cyan,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:api": "python -m uvicorn main:app --reload --app-dir apps/api/src --host 0.0.0.0 --port 8000",
    "build:web": "npm --prefix apps/web run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
